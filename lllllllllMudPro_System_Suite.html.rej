 // ═══ HEADER ══════════════════════════════════════════════════════
 function updHdr(){
   const rig=document.getElementById('tb-rig')?.value||'T-907';const well=document.getElementById('tb-well')?.value||'';
   const dv=document.getElementById('tb-date')?.value;let ds='';
   if(dv){const d=new Date(dv+'T12:00');ds=d.toLocaleDateString('en-GB',{day:'2-digit',month:'2-digit',year:'numeric'}).replace(/\//g,'-')}
   document.getElementById('rh-rig').textContent=`${rig}${well?' — '+well:''} — MUD SYSTEM LAY OUT`;
   document.getElementById('rh-date').textContent=ds;
