 }
 
 
 let undoStack=[],redoStack=[];
 function pushUndo(lbl){
   undoStack.push({lbl:lbl,s:JSON.stringify(pits),n:nid});
   if(undoStack.length>30)undoStack.shift();
   redoStack=[];_updUndo();
 }
 function doUndo(){
   if(!undoStack.length)return;
   redoStack.push({s:JSON.stringify(pits),n:nid,lbl:'redo'});
   const p=undoStack.pop();pits=JSON.parse(p.s);nid=p.n;
   save();resGrid();renderSummary();renderCatCounts();renderNotes();calcDelta();
   toast('↩ Undid: '+p.lbl);_updUndo();
 }
